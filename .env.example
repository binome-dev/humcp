# PostgreSQL
# DATABASE_URL=postgresql://user:password@localhost:5432/mydb

# Redshift
# REDSHIFT_HOST=your-cluster.redshift.amazonaws.com
# REDSHIFT_DATABASE=your-database
# REDSHIFT_USER=your-user
