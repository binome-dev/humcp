# -----------------------------------------------------------------------------
# Local Tools
# -----------------------------------------------------------------------------
# Allow shell/file tools to use absolute paths (default: false for safety)
# HUMCP_ALLOW_ABSOLUTE_PATHS=false
# STORAGE_ALLOW_ABSOLUTE_PATHS=false
