# Only include what the toolset Dockerfile needs: shared/ and toolset/
*

# Include shared package
!shared/
shared/**/__pycache__/

# Include toolset source and config
!toolset/
toolset/.venv/
toolset/__pycache__/
toolset/**/__pycache__/
toolset/.pytest_cache/
toolset/tests/
toolset/.env
toolset/.env.*
toolset/.git/
toolset/dist/
toolset/build/
toolset/*.egg-info/
